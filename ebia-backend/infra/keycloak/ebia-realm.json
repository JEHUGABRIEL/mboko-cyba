{
  "realm": "ebia",
  "displayName": "E-Bia",
  "enabled": true,
  "sslRequired": "external",
  "registrationAllowed": true,
  "loginWithEmailAllowed": true,
  "resetPasswordAllowed": true,
  "rememberMe": true,
  "defaultLocale": "fr",
  "accessTokenLifespan": 900,
  "roles": {
    "realm": [
      { "name": "listener", "description": "Auditeur" },
      { "name": "artist", "description": "Artiste" },
      { "name": "admin", "description": "Administrateur" }
    ]
  },
  "defaultRoles": ["listener"],
  "clients": [
    {
      "clientId": "ebia-web",
      "name": "E-Bia Web App",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "redirectUris": ["https://e-bia.onrender.com/*", "http://localhost:3000/*"],
      "webOrigins": ["https://e-bia.onrender.com", "http://localhost:3000"],
      "attributes": { "pkce.code.challenge.method": "S256" }
    },
    {
      "clientId": "ebia-mobile",
      "name": "E-Bia Flutter App",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "redirectUris": ["com.ebia.app://callback", "http://localhost:*"],
      "attributes": { "pkce.code.challenge.method": "S256" }
    }
  ]
}
