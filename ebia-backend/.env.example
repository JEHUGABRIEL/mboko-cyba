# ── Base de données ──────────────────────────────────────────
POSTGRES_PASSWORD=1344968db6e238a2d6d87235ec5f55e180ac3a3eac13fb1f9887210a555995c6

# ── Sécurité ─────────────────────────────────────────────────
# Générer avec : openssl rand -hex 64
JWT_SECRET=change_me_generate_with_openssl_rand_hex_64

# ── Stockage objet (MinIO) ───────────────────────────────────
MINIO_ACCESS_KEY=ebia_minio_admin
